function SeasonalClock() {
  const seasons = [
    { name: "Spring", icon: "🌱", color: C.spring, action: "Emerge", desc: "New quests sprout. Dormant ones reawaken. Equinox gathering.", months: "Mar – May", angle: 0 },
    { name: "Summer", icon: "☀️", color: C.summer, action: "Build", desc: "Active construction. Resource mobilization. Peak energy.", months: "Jun – Aug", angle: 90 },
    { name: "Autumn", icon: "🍂", color: C.autumn, action: "Harvest", desc: "Reflect. Document. Share learnings. Gratitude.", months: "Sep – Nov", angle: 180 },
    { name: "Winter", icon: "❄️", color: C.winter, action: "Rest", desc: "Integration. Pruning stale quests. Deep work. Solstice pause.", months: "Dec – Feb", angle: 270 },
  ];
  const now = new Date();
  const month = now.getMonth();
  const currentSeason = month >= 2 && month <= 4 ? 0 : month >= 5 && month <= 7 ? 1 : month >= 8 && month <= 10 ? 2 : 3;

  return (
    <section style={{ padding: "80px 20px", maxWidth: 800, margin: "0 auto" }}>
      <F>
        <div style={{ ...sf, fontSize: "clamp(1.6rem, 3vw, 2.2rem)", fontWeight: 300, textAlign: "center", marginBottom: 6 }}>Seasonal rhythm</div>
        <p style={{ textAlign: "center", color: C.txtD, fontSize: 12, maxWidth: 480, margin: "0 auto 36px", lineHeight: 1.8 }}>Quests follow the seasons. Not arbitrary deadlines — natural cycles of emergence, building, harvesting, and rest.</p>
      </F>
      {/* Clock SVG */}
      <F>
        <div style={{ display: "flex", justifyContent: "center", marginBottom: 28 }}>
          <svg viewBox="0 0 300 300" style={{ width: 240, height: 240 }}>
            {seasons.map((s, i) => {
              const a1 = (s.angle - 45) * Math.PI / 180;
              const a2 = (s.angle + 45) * Math.PI / 180;
              const cx = 150, cy = 150, r = 110;
              const x1 = cx + r * Math.cos(a1), y1 = cy + r * Math.sin(a1);
              const x2 = cx + r * Math.cos(a2), y2 = cy + r * Math.sin(a2);
              const mx = cx + (r + 20) * Math.cos(s.angle * Math.PI / 180);
              const my = cy + (r + 20) * Math.sin(s.angle * Math.PI / 180);
              const isCurrent = i === currentSeason;
              return (
                <g key={i}>
                  <path d={`M${cx},${cy} L${x1},${y1} A${r},${r} 0 0,1 ${x2},${y2} Z`}
                    fill={isCurrent ? `${s.color}30` : `${s.color}10`} stroke={s.color} strokeWidth={isCurrent ? 2 : 0.5} />
                  <text x={cx + 72 * Math.cos(s.angle * Math.PI / 180)} y={cy + 72 * Math.sin(s.angle * Math.PI / 180)}
                    textAnchor="middle" dominantBaseline="middle" fontSize="20">{s.icon}</text>
                  <text x={cx + 48 * Math.cos(s.angle * Math.PI / 180)} y={cy + 48 * Math.sin(s.angle * Math.PI / 180) + 14}
                    textAnchor="middle" fontSize="8" fill={s.color} fontFamily="DM Sans">{s.action}</text>
                </g>
              );
            })}
            <circle cx={150} cy={150} r={18} fill={C.bgC} stroke={C.brd} />
            <text x={150} y={150} textAnchor="middle" dominantBaseline="middle" fontSize="7" fill={C.txtM} fontFamily="DM Sans">NOW</text>
            {/* Current season indicator */}
            <circle cx={150 + 30 * Math.cos(seasons[currentSeason].angle * Math.PI / 180)}
              cy={150 + 30 * Math.sin(seasons[currentSeason].angle * Math.PI / 180)} r={4} fill={seasons[currentSeason].color} />
          </svg>
        </div>
      </F>
      <div style={{ display: "grid", gridTemplateColumns: "repeat(auto-fit, minmax(160px, 1fr))", gap: 10 }}>
        {seasons.map((s, i) => (
          <F key={i} style={{ borderTop: `3px solid ${s.color}`, background: i === currentSeason ? C.bgC : C.bgL, padding: "14px 14px", borderRadius: "0 0 4px 4px" }}>
            <div style={{ fontSize: 11, fontWeight: 500, color: s.color, marginBottom: 4 }}>{s.icon} {s.name}</div>
            <div style={{ fontSize: 10, color: C.txtD, lineHeight: 1.6, marginBottom: 4 }}>{s.desc}</div>
            <div style={{ fontSize: 9, color: C.txtM }}>{s.months}</div>
          </F>
        ))}
      </div>
    </section>
  );
}

