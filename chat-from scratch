// QUEST GRAPH VISUALIZATION
// ═══════════════════════════════════════
function QuestGraph() {
  const canvasRef = useRef(null);
  const [hovered, setHovered] = useState(null);

  // Sample quest nodes
  const nodes = [
    { id: 0, x: 300, y: 150, r: 20, label: "Community Garden Wien", stage: "building", color: C.summer },
    { id: 1, x: 180, y: 100, r: 14, label: "Seed Library Graz", stage: "connecting", color: C.sys },
    { id: 2, x: 420, y: 120, r: 12, label: "Food Coop Linz", stage: "planning", color: C.warm },
    { id: 3, x: 260, y: 240, r: 16, label: "Soil Regeneration AT", stage: "articulating", color: C.acc },
    { id: 4, x: 150, y: 200, r: 10, label: "Composting Feldbach", stage: "dreaming", color: C.evo },
    { id: 5, x: 440, y: 220, r: 11, label: "Urban Farm München", stage: "sustaining", color: C.spring },
    { id: 6, x: 360, y: 270, r: 9, label: "Permakultur Zürich", stage: "connecting", color: C.sys },
    { id: 7, x: 100, y: 150, r: 8, label: "Water Rights Tirol", stage: "articulating", color: C.acc },
  ];
  const edges = [[0,1],[0,2],[0,3],[1,4],[3,4],[2,5],[3,6],[1,7],[5,6]];

  useEffect(() => {
    const cv = canvasRef.current; if (!cv) return;
    const ctx = cv.getContext("2d");
    const w = cv.width = cv.offsetWidth * 2; const h = cv.height = cv.offsetHeight * 2;
    const sx = w / 540, sy = h / 320;
    ctx.clearRect(0, 0, w, h);

    // Edges
    edges.forEach(([a, b]) => {
      const na = nodes[a], nb = nodes[b];
      ctx.beginPath(); ctx.moveTo(na.x * sx, na.y * sy); ctx.lineTo(nb.x * sx, nb.y * sy);
      ctx.strokeStyle = `${C.acc}25`; ctx.lineWidth = 1.5; ctx.stroke();
    });

    // Nodes
    nodes.forEach(n => {
      const x = n.x * sx, y = n.y * sy, r = n.r * (sx + sy) / 2 * 0.5;
      // Glow
      const g = ctx.createRadialGradient(x, y, 0, x, y, r * 3);
      g.addColorStop(0, `${n.color}25`); g.addColorStop(1, "transparent");
      ctx.fillStyle = g; ctx.fillRect(x - r * 3, y - r * 3, r * 6, r * 6);
      // Circle
      ctx.beginPath(); ctx.arc(x, y, r, 0, Math.PI * 2);
      ctx.fillStyle = `${n.color}90`; ctx.fill();
      ctx.strokeStyle = n.color; ctx.lineWidth = 1; ctx.stroke();
      // Label
      ctx.fillStyle = `${C.txt}cc`; ctx.font = `${Math.max(14, r * 0.9)}px DM Sans`;
      ctx.textAlign = "center"; ctx.fillText(n.label, x, y - r - 6);
    });
  }, []);

  return (
    <section style={{ padding: "80px 20px", maxWidth: 860, margin: "0 auto" }}>
      <F>
        <div style={{ ...sf, fontSize: "clamp(1.6rem, 3vw, 2.2rem)", fontWeight: 300, textAlign: "center", marginBottom: 6 }}>The quest graph</div>
        <p style={{ textAlign: "center", color: C.txtD, fontSize: 12, maxWidth: 500, margin: "0 auto 28px" }}>
          Quests connect through resonance, complementary resources, shared bioregions, and vertical alliances. Every node is sovereign; every edge is consensual.
        </p>
      </F>
      <F>
        <Card style={{ padding: 0, overflow: "hidden" }}>
          <canvas ref={canvasRef} style={{ width: "100%", height: 280, display: "block" }} />
          <div style={{ padding: "14px 18px", borderTop: `1px solid ${C.brd}`, display: "flex", gap: 12, flexWrap: "wrap" }}>
            {[["💭", "Dreaming", C.evo], ["✍️", "Articulating", C.acc], ["🔗", "Connecting", C.sys], ["📐", "Planning", C.warm], ["🔨", "Building", C.summer], ["🌳", "Sustaining", C.spring]].map(([i, l, c], idx) => (
              <span key={idx} style={{ fontSize: 9, color: c, display: "flex", alignItems: "center", gap: 3 }}>
                <span style={{ width: 6, height: 6, borderRadius: "50%", background: c, display: "inline-block" }} /> {l}
              </span>
            ))}
          </div>
        </Card>
      </F>
    </section>
  );
}

