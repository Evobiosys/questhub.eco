function useFade() {
  const r = useRef(null);
  useEffect(() => {
    const el = r.current; if (!el) return;
    Object.assign(el.style, { opacity: "0", transform: "translateY(18px)", transition: "opacity 0.6s ease, transform 0.6s ease" });
    const o = new IntersectionObserver(([e]) => { if (e.isIntersecting) { el.style.opacity = "1"; el.style.transform = "translateY(0)"; o.disconnect(); } }, { threshold: 0.08 });
    o.observe(el); return () => o.disconnect();
  }, []); return r;
}
function F({ children, style }) { const r = useFade(); return <div ref={r} style={style}>{children}</div>; }
function Btn({ children, active, onClick, small, color }) {
  return <button onClick={onClick} style={{ ...sn, background: active ? (color || C.accG) : "transparent", border: `1px solid ${active ? C.accD : C.brd}`, color: active ? C.acc : C.txtM, padding: small ? "4px 10px" : "7px 14px", fontSize: small ? 10 : 11, borderRadius: 2, cursor: "pointer", transition: "all 0.2s" }}>{children}</button>;
}
function Card({ children, style }) { return <div style={{ background: C.bgC, border: `1px solid ${C.brd}`, borderRadius: 4, padding: "20px 18px", ...style }}>{children}</div>; }
function Label({ children }) { return <div style={{ fontSize: 9, color: C.txtM, letterSpacing: 2, textTransform: "uppercase", marginBottom: 8 }}>{children}</div>; }

